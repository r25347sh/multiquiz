section: "大問3: 英文並び替え問題"

// 41.
{
  question: "以下の語句を正しい順序に並び替えて自然な英文にしてください。",
  type: "sort",
  items: ["the environment", "protecting", "is crucial", "for future generations"],
  correct: ["protecting", "the environment", "is crucial", "for future generations"],
  note: "Protecting the environment is crucial for future generations."
}

