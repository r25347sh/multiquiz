// ========================================
// タイトル・全体設定
// ========================================
title: "高校英語 総合クイズ - Vocabulary & Grammar Mastery"
description: "高校レベルの英語力を強化するための総合クイズ。単語の意味理解、文法・語法の穴埋め、並び替えを中心に50問出題。基本的に各問題2点。性能重視で正確な理解を促す設計。"
points_default: 2

// ========================================
// 変数定義（任意）
// ========================================
username = "学習者";
year = 2026;

