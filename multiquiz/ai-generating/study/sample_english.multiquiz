section: "大問2: 文中穴埋め問題"

// 31.
{
  question: "The scientist conducted an experiment to _____ the effects of climate change. [[1]]",
  type: "fill",
  blanks: {
    "1": "investigate"
  },
  note: "investigate = 調査する。"
}

// 32.
{
  question: "Despite the difficulties, she remained _____ and achieved her goal. [[1]]",
  type: "fill",
  blanks: {
    "1": "determined"
  },
  note: "determined = 決意した。"
}

// 33.
{
  question: "The government is trying to _____ pollution in big cities. [[1]]",
